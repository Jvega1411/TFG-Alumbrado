# .env para nodo OT (RPi) — copiar a ~/dev/alumbrado-gateway/.env
# Solo contiene variables que usa el publisher (Plan B).
# Variables SQLite/FastAPI/API NO se usan en RPi.

# ---------------------------------------------------------------------------
# PLC Omron CJ2M CPU32
# ---------------------------------------------------------------------------
PLC_IP=192.168.250.1
PLC_PORT=9600
UDP_LOCAL_PORT=9600
UDP_TIMEOUT=2.0

# FINS — nodos fisicos del rack. Leer en la pantalla del PLC o con CX-Programmer.
# SOURCE_NODE = nodo IP del host que hace la peticion (RPi en la red OT)
# DEST_NODE   = nodo IP del PLC (normalmente el ultimo octeto de PLC_IP: 1)
FINS_SOURCE_NETWORK=0
FINS_SOURCE_NODE=<PENDIENTE — ver rack, ej. 220 si RPi es 192.168.250.220>
FINS_SOURCE_UNIT=0
FINS_DEST_NETWORK=0
FINS_DEST_NODE=1
FINS_DEST_UNIT=0

# ---------------------------------------------------------------------------
# Adquisicion
# ---------------------------------------------------------------------------
ACQUISITION_INTERVAL_S=30
HEARTBEAT_INTERVAL_S=300

# ---------------------------------------------------------------------------
# MQTT — publisher envia al broker en Lenovo
# ---------------------------------------------------------------------------
MQTT_BROKER_HOST=10.0.0.2
MQTT_BROKER_PORT=1883
MQTT_TOPIC=alumbrado/estado
MQTT_CLIENT_ID=alumbrado-publisher
# Dejar vacio en dev (Mosquitto allow_anonymous true)
MQTT_USERNAME=
MQTT_PASSWORD=

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
LOG_DIR=logs
