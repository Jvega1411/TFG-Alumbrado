# .env para nodo IT (Lenovo) — copiar a C:\alumbrado-gateway\.env
# Variables PLC/FINS NO se usan en Lenovo; dejar en blanco o sin este bloque.

# ---------------------------------------------------------------------------
# MQTT — subscriber se conecta al broker local (Mosquitto en este mismo equipo)
# ---------------------------------------------------------------------------
MQTT_BROKER_HOST=10.0.0.2
MQTT_BROKER_PORT=1883
MQTT_TOPIC=alumbrado/estado
# Dev controlado: se pueden dejar vacios si Mosquitto usa allow_anonymous true.
# Produccion: Mosquitto debe usar allow_anonymous false + password_file; poner secretos solo en .env real.
MQTT_USERNAME=
MQTT_PASSWORD=

# ---------------------------------------------------------------------------
# SQLite — base de datos local de estados
# ---------------------------------------------------------------------------
DB_ESTADOS_URL=sqlite:///C:/alumbrado-gateway/data/bd_estados.db
# V3 clean break: true crea el esquema limpio si el fichero SQLite es nuevo.
# Tras verificar el primer arranque, puede dejarse en false si se prefiere.
DB_AUTO_CREATE=true

# ---------------------------------------------------------------------------
# FastAPI — dashboard web
# 0.0.0.0 expone en toda la red corporativa (acceso desde otros equipos).
# Usarlo solo con firewall restrictivo y red autorizada. En produccion, preferir reverse proxy/VPN/TLS.
# 127.0.0.1 solo acceso local
# ---------------------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
LOG_DIR=logs
