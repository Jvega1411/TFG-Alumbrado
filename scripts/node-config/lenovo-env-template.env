# .env para nodo IT (Lenovo) — copiar a C:\alumbrado-gateway\.env
# Variables PLC/FINS NO se usan en Lenovo; dejar en blanco o sin este bloque.

# ---------------------------------------------------------------------------
# MQTT — subscriber se conecta al broker local (Mosquitto en este mismo equipo)
# ---------------------------------------------------------------------------
MQTT_BROKER_HOST=10.0.0.2
MQTT_BROKER_PORT=1883
MQTT_TOPIC=alumbrado/estado
# MQTT_USERNAME y MQTT_PASSWORD: dejar vacíos en dev (allow_anonymous true)
MQTT_USERNAME=
MQTT_PASSWORD=

# ---------------------------------------------------------------------------
# SQLite — base de datos local de estados
# ---------------------------------------------------------------------------
DB_ESTADOS_URL=sqlite:///C:/alumbrado-gateway/data/bd_estados.db
DB_AUTO_CREATE=false

# ---------------------------------------------------------------------------
# FastAPI — dashboard web
# 0.0.0.0 expone en toda la red corporativa (acceso desde otros equipos)
# 127.0.0.1 solo acceso local
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
LOG_DIR=logs
