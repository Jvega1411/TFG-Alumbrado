# Copiar a .env y rellenar con valores reales. No subir .env a git.

# PLC Omron CJ2M CPU32
PLC_IP=
PLC_PORT=9600
UDP_LOCAL_PORT=9600

# FINS — verificar nodos físicamente en rack antes de arrancar
FINS_SOURCE_NETWORK=0
FINS_SOURCE_NODE=
FINS_SOURCE_UNIT=0
FINS_DEST_NETWORK=0
FINS_DEST_NODE=
FINS_DEST_UNIT=0

# Timeout UDP en segundos
UDP_TIMEOUT=2.0

# SQL Server
DB_SERVER=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_PORT=1433

# Intervalo de adquisición en segundos
ACQUISITION_INTERVAL_S=30

# Directorio de logs (relativo a raíz del proyecto)
LOG_DIR=logs
