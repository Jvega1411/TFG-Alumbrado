# Copiar a .env y rellenar con valores reales. No subir .env a git.
#
# Nodo OT (RPi): requiere PLC_*, FINS_*, MQTT_BROKER_HOST, MQTT_TOPIC, ACQUISITION_INTERVAL_S
# Nodo IT (Lenovo): requiere MQTT_BROKER_HOST, MQTT_TOPIC, DB_ESTADOS_URL, API_HOST, API_PORT

# ---------------------------------------------------------------------------
# PLC Omron CJ2M CPU32  [solo RPi]
# ---------------------------------------------------------------------------
PLC_IP=192.168.250.1
PLC_PORT=9600
UDP_LOCAL_PORT=9600
UDP_LOCAL_HOST=
UDP_TIMEOUT=2.0

# Nodos FINS — verificar en rack antes de arrancar (0-255)
FINS_SOURCE_NETWORK=0
FINS_SOURCE_NODE=0
FINS_SOURCE_UNIT=0
FINS_DEST_NETWORK=0
FINS_DEST_NODE=1
FINS_DEST_UNIT=0

# ---------------------------------------------------------------------------
# Adquisición  [solo RPi]
# ---------------------------------------------------------------------------
ACQUISITION_INTERVAL_S=30
HEARTBEAT_INTERVAL_S=300

# ---------------------------------------------------------------------------
# MQTT  [RPi: publisher | Lenovo: subscriber]
# ---------------------------------------------------------------------------
# RPi apunta a 10.0.0.2, Lenovo apunta a 10.0.0.2 (localhost del broker)
MQTT_BROKER_HOST=10.0.0.2
MQTT_BROKER_PORT=1883
MQTT_TOPIC=alumbrado/estado
MQTT_CLIENT_ID=alumbrado-publisher
# Dev controlado: se pueden dejar vacios si Mosquitto usa allow_anonymous true.
# Produccion: configurar Mosquitto con allow_anonymous false + password_file y rellenar usuario/password reales solo en .env.
MQTT_USERNAME=
MQTT_PASSWORD=

# ---------------------------------------------------------------------------
# Base de datos SQLite  [solo Lenovo]
# ---------------------------------------------------------------------------
# Ruta absoluta recomendada en producción, relativa aceptable en dev
DB_ESTADOS_URL=sqlite:///data/bd_estados.db
DB_HIST_URL=sqlite:///data/bd_historizacion.db
# true solo en dev sin Alembic. En producción usar: alembic upgrade head
DB_AUTO_CREATE=false

# ---------------------------------------------------------------------------
# FastAPI / dashboard  [solo Lenovo]
# ---------------------------------------------------------------------------
# 127.0.0.1 sirve solo en local. Usar 0.0.0.0 solo si hay firewall restrictivo y red autorizada.
# Para produccion, publicar detras de reverse proxy/VPN/TLS o una regla equivalente definida fuera de este template.
API_HOST=127.0.0.1
API_PORT=8000

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
LOG_DIR=logs
